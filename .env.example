# --- argus's own DB ---
DATABASE_URL=postgresql+psycopg://argus:argus@postgres:5432/argus
DATABASE_URL_SYNC=postgresql+psycopg://argus:argus@postgres:5432/argus

# --- hollywood postgres (READ-ONLY seed source for P0) ---
HOLLYWOOD_DATABASE_URL=postgresql+psycopg://hollywood:hollywood@postgres.hollywood.svc.cluster.local:5432/hollywood

# --- neo4j ---
NEO4J_ENABLED=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=argus

# --- resolution parameters ---
RESOLUTION_SIMILARITY_THRESHOLD=0.86
RESOLUTION_PERSON_CONSERVATIVE_MARGIN=0.04
RESOLUTION_TOP_K=8

# --- llm (scrutiny agent + P1 downstream) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- public ---
PUBLIC_BASE_URL=https://argus.tonyvigna.com
